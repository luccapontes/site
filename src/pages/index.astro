---
import Base from '../layouts/Base.astro';
import BlogRow from '../components/BlogRow.astro';
import ProjectCard from '../components/ProjectCard.astro';
import BookCard from '../components/BookCard.astro';
import { getCollection } from 'astro:content';
import leituras from '../data/leituras.json';

const ptPosts = (await getCollection('blog', ({ data }) => !data.draft && data.lang === 'pt'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 5);

const enPosts = (await getCollection('blog', ({ data }) => !data.draft && data.lang === 'en'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 5);

const ptProjects = (await getCollection('projetos', ({ data }) => data.featured && data.lang === 'pt'))
  .sort((a, b) => (b.data.year ?? 0) - (a.data.year ?? 0));

const enProjects = (await getCollection('projetos', ({ data }) => data.featured && data.lang === 'en'))
  .sort((a, b) => (b.data.year ?? 0) - (a.data.year ?? 0));

const lidas = leituras.filter(l => l.status === 'lido').slice(0, 3);
const proxima = leituras.find(l => l.status === 'quero');
---

<Base title="lucca pontes" description="desenvolvedor e representante comercial. trabalho na interseção entre tecnologia e vendas.">

  <!-- Hero -->
  <section class="hero">
    <div class="hero-content">
      <span class="hero-tag" data-pt="DESENVOLVEDOR & REPRESENTANTE COMERCIAL" data-en="DEVELOPER & SALES REPRESENTATIVE">DESENVOLVEDOR & REPRESENTANTE COMERCIAL</span>
      <h1 class="hero-title" data-pt="olá, sou lucca pontes." data-en="hi, i'm lucca pontes.">olá, sou lucca pontes.</h1>
      <p class="hero-desc" data-lang="pt">
        trabalho na interseção entre tecnologia e vendas. fui desenvolvedor por anos e hoje represento
        a mesma software house onde comecei — entendendo os dois lados do produto.
      </p>
      <p class="hero-desc" data-lang="en">
        i work at the intersection of technology and sales. i spent years as a developer and now i represent
        the same software house where i started — understanding both sides of the product.
      </p>
      <div class="hero-pills">
        <span class="pill">Alphacode</span>
        <span class="pill">mobile & web</span>
        <span class="pill" data-pt="vendas b2b" data-en="b2b sales">vendas b2b</span>
        <span class="pill" data-pt="inglês avançado" data-en="advanced english">inglês avançado</span>
      </div>
    </div>
    <img src="/images/centralizada.jpeg" alt="Lucca Pontes" class="hero-avatar" />
  </section>

  <!-- Blog -->
  <section class="home-section">
    <div class="section-header">
      <span class="section-label" data-pt="BLOG — ÚLTIMAS PUBLICAÇÕES" data-en="BLOG — LATEST POSTS">BLOG — ÚLTIMAS PUBLICAÇÕES</span>
      <a href="/blog" class="btn-secondary" data-pt="ver todos os posts" data-en="see all posts">ver todos os posts</a>
    </div>
    <div class="blog-list" data-lang="pt">
      {ptPosts.map((post, i) => (
        <BlogRow
          num={i + 1}
          title={post.data.title}
          date={post.data.date.toISOString()}
          slug={post.slug}
          category={post.data.category}
        />
      ))}
    </div>
    <div class="blog-list" data-lang="en">
      {enPosts.map((post, i) => (
        <BlogRow
          num={i + 1}
          title={post.data.title}
          date={post.data.date.toISOString()}
          slug={post.slug}
          category={post.data.category}
        />
      ))}
    </div>
  </section>

  <!-- Projetos -->
  <section class="home-section">
    <span class="section-label" data-pt="PROJETOS SELECIONADOS" data-en="SELECTED PROJECTS">PROJETOS SELECIONADOS</span>
    <div class="proj-grid" data-lang="pt">
      {ptProjects.map(proj => (
        <ProjectCard
          title={proj.data.title}
          year={proj.data.year}
          type={proj.data.type}
          description={proj.data.description}
          tech={proj.data.tech}
          demo={proj.data.demo}
          github={proj.data.github}
          slug={proj.slug}
        />
      ))}
    </div>
    <div class="proj-grid" data-lang="en">
      {enProjects.map(proj => (
        <ProjectCard
          title={proj.data.title}
          year={proj.data.year}
          type={proj.data.type}
          description={proj.data.description}
          tech={proj.data.tech}
          demo={proj.data.demo}
          github={proj.data.github}
          slug={proj.slug}
        />
      ))}
    </div>
  </section>

  <!-- Leituras -->
  <section class="home-section">
    <span class="section-label" data-pt="LEITURAS RECENTES" data-en="RECENT READS">LEITURAS RECENTES</span>
    <div class="books-grid">
      {lidas.map(livro => (
        <BookCard
          title={livro.title}
          author={livro.author}
          status={livro.status as 'lido'}
          rating={livro.rating}
          review={livro.review}
        />
      ))}
      {proxima && (
        <BookCard
          title={proxima.title}
          author={proxima.author}
          status="quero"
          review={proxima.review}
          dashed={true}
        />
      )}
    </div>
  </section>

</Base>

<style>
  .hero {
    padding: 56px 0 48px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
  }
  .hero-content {
    display: flex;
    flex-direction: column;
    gap: 16px;
    flex: 1;
  }
  .hero-avatar {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    border: 0.5px solid var(--border);
    object-fit: cover;
    object-position: center top;
    flex-shrink: 0;
  }
  .hero-tag {
    font-size: 11px;
    color: var(--text-hint);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .hero-title {
    font-size: 40px;
    font-weight: 500;
    color: var(--text-primary);
    line-height: 1.15;
  }
  .hero-desc {
    font-size: 14px;
    color: var(--text-muted);
    max-width: 500px;
    line-height: 1.7;
  }
  .hero-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 4px;
  }

  .home-section {
    padding: 40px 0;
    border-top: 0.5px solid var(--border);
  }
  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
  }
  .section-header .section-label {
    margin-bottom: 0;
  }

  .blog-list {
    display: flex;
    flex-direction: column;
  }

  .proj-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin-top: 16px;
  }

  .books-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin-top: 16px;
  }

  @media (max-width: 720px) {
    .proj-grid { grid-template-columns: repeat(2, 1fr); }
    .hero-avatar { width: 96px; height: 96px; }
  }

  @media (max-width: 480px) {
    .proj-grid { grid-template-columns: 1fr; }
    .books-grid { grid-template-columns: repeat(2, 1fr); }
    .hero-title { font-size: 28px; }
    .hero-avatar { display: none; }
  }

  @media (max-width: 420px) {
    .books-grid { grid-template-columns: 1fr; }
    .hero-title { font-size: 24px; }
  }
</style>
