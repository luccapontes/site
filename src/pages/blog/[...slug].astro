---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { DynamicIslandTOC } from '../../components/ui/dynamic-island-toc';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const lang = post.data.lang ?? 'pt';
const locale = lang === 'en' ? 'en-US' : 'pt-BR';
const backText = lang === 'en' ? '← back to blog' : '← voltar para o blog';

function formatDate(d: Date) {
  return d.toLocaleDateString(locale, { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<Base title={post.data.title} description={post.data.description}>

  <DynamicIslandTOC client:only="react" lang={lang} />

  <div class="article-header">
    <a href="/blog" class="back-link">{backText}</a>
    <h1 class="article-title">{post.data.title}</h1>
    <div class="article-meta">
      <span class="article-date">{formatDate(post.data.date)}</span>
      <span class="article-sep">·</span>
      <span class="article-cat">{post.data.category}</span>
    </div>
  </div>

  <article class="article-content">
    <Content />
  </article>

  <div class="article-footer">
    <a href="/blog" class="btn-secondary">{backText}</a>
  </div>

</Base>

<style>
  .article-header {
    padding: 48px 0 32px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    border-bottom: 0.5px solid var(--border);
    margin-bottom: 32px;
  }
  .back-link {
    font-size: 13px;
    color: var(--text-hint);
    transition: color 0.15s;
  }
  .back-link:hover {
    color: var(--text-primary);
  }
  .article-title {
    font-size: 28px;
    font-weight: 500;
    color: var(--text-primary);
    line-height: 1.3;
  }
  .article-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--text-hint);
  }
  .article-sep {
    color: var(--border-hover);
  }

  .article-content {
    font-size: 15px;
    color: var(--text-body);
    line-height: 1.8;
  }
  .article-content :global(h2) {
    font-size: 20px;
    font-weight: 500;
    color: var(--text-primary);
    margin: 32px 0 12px;
  }
  .article-content :global(h3) {
    font-size: 16px;
    font-weight: 500;
    color: var(--text-primary);
    margin: 24px 0 8px;
  }
  .article-content :global(p) {
    margin-bottom: 16px;
  }
  .article-content :global(ul),
  .article-content :global(ol) {
    margin: 12px 0 16px 20px;
  }
  .article-content :global(li) {
    margin-bottom: 6px;
  }
  .article-content :global(strong) {
    color: var(--text-primary);
    font-weight: 500;
  }
  .article-content :global(code) {
    background: var(--bg-card);
    border: 0.5px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 1px 5px;
    font-size: 13px;
    font-family: 'Monaco', 'Courier New', monospace;
  }
  .article-content :global(pre) {
    background: var(--bg-card);
    border: 0.5px solid var(--border);
    border-radius: var(--radius-md);
    padding: 16px;
    overflow-x: auto;
    margin: 16px 0;
  }
  .article-content :global(blockquote) {
    border-left: 2px solid var(--border-hover);
    padding-left: 16px;
    color: var(--text-muted);
    margin: 16px 0;
  }

  .article-footer {
    margin-top: 48px;
    padding-top: 24px;
    border-top: 0.5px solid var(--border);
  }
</style>
