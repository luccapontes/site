---
import Base from '../layouts/Base.astro';
import CertCard from '../components/CertCard.astro';
import timeline from '../data/timeline.json';
import certificados from '../data/certificados.json';
---

<Base title="sobre" description="trajetória, habilidades e o que estou lendo agora.">

  <div class="page-header">
    <h1 class="page-title" data-pt="sobre" data-en="about">sobre</h1>
  </div>

  <!-- Avatar + Bio -->
  <section class="about-section">
    <div class="about-grid">
      <div class="avatar-col">
        <img src="/images/centralizada.jpeg" alt="Lucca Pontes" class="avatar-img" />
        <span class="cargo" data-pt="representante comercial · Alphacode" data-en="sales representative · Alphacode">representante comercial · Alphacode</span>
      </div>
      <div class="bio-col">
        <div class="bio-paras" data-lang="pt">
          <p>Entrei na <strong>Alphacode</strong> em 2017, com 15 anos, e passei quase 7 anos construindo produtos reais — mobile, web, APIs, fintech. Trabalhei em projetos como Habib's, Ragazzo e Gipay, com clientes brasileiros e internacionais.</p>
          <p>No final de 2025 migrei para o comercial. Hoje represento a mesma empresa onde cresci como dev — e isso muda tudo: consigo falar de arquitetura, prazos e limitações técnicas com o cliente sem depender de intermediário.</p>
          <p>Acredito que os melhores representantes de software do futuro serão pessoas que entendem o que está sendo construído. Escrevo sobre essa interseção entre tecnologia e vendas.</p>
        </div>
        <div class="bio-paras" data-lang="en">
          <p>I joined <strong>Alphacode</strong> in 2017, at 15 years old, and spent nearly 7 years building real products — mobile, web, APIs, fintech. I worked on projects like Habib's, Ragazzo and Gipay, with both Brazilian and international clients.</p>
          <p>In late 2025 I transitioned to sales. Today I represent the same company where I grew as a developer — and that changes everything: I can discuss architecture, timelines, and technical limitations directly with clients without needing an intermediary.</p>
          <p>I believe the best software sales reps of the future will be people who understand what's being built. I write about this intersection between technology and sales.</p>
        </div>
        <div class="bio-pills">
          <span class="pill">Alphacode</span>
          <span class="pill">mobile & web</span>
          <span class="pill" data-pt="vendas b2b" data-en="b2b sales">vendas b2b</span>
          <span class="pill" data-pt="inglês avançado" data-en="advanced english">inglês avançado</span>
        </div>
      </div>
    </div>
  </section>

  <hr />

  <!-- Trajetória -->
  <section class="about-section">
    <span class="section-label" data-pt="TRAJETÓRIA" data-en="TRAJECTORY">TRAJETÓRIA</span>
    <div class="timeline">
      {timeline.map((item, i) => (
        <div class="timeline-item">
          <div class="timeline-year">{item.year}</div>
          <div class="timeline-content">
            <div class="timeline-title" data-pt={item.title} data-en={item.title_en}>{item.title}</div>
            <div class="timeline-desc" data-pt={item.description} data-en={item.description_en}>{item.description}</div>
          </div>
          {i < timeline.length - 1 && <div class="timeline-line"></div>}
        </div>
      ))}
    </div>
  </section>

  <hr />

  <!-- Habilidades -->
  <section class="about-section">
    <span class="section-label" data-pt="HABILIDADES" data-en="SKILLS">HABILIDADES</span>
    <div class="skills-grid">
      <div class="skills-col">
        <span class="skills-group-label" data-pt="DESENVOLVIMENTO" data-en="DEVELOPMENT">DESENVOLVIMENTO</span>
        <ul class="skills-list">
          <li>TypeScript</li>
          <li>Angular</li>
          <li>Ionic</li>
          <li>React / React Native</li>
          <li>Node.js</li>
          <li>PHP</li>
          <li>HTML / CSS / SCSS</li>
          <li>MySQL</li>
          <li>Git / Firebase</li>
          <li>APIs REST & integrações</li>
        </ul>
      </div>
      <div class="skills-col">
        <span class="skills-group-label" data-pt="COMERCIAL & GESTÃO" data-en="BUSINESS & MANAGEMENT">COMERCIAL & GESTÃO</span>
        <ul class="skills-list">
          <li data-pt="Vendas consultivas B2B" data-en="B2B consultative sales">Vendas consultivas B2B</li>
          <li data-pt="Comunicação com clientes" data-en="Client communication">Comunicação com clientes</li>
          <li data-pt="Propostas comerciais" data-en="Commercial proposals">Propostas comerciais</li>
          <li data-pt="Coordenação de equipe" data-en="Team coordination">Coordenação de equipe</li>
          <li data-pt="Planejamento de entregas" data-en="Delivery planning">Planejamento de entregas</li>
          <li data-pt="Documentação técnica" data-en="Technical documentation">Documentação técnica</li>
          <li data-pt="Negociação" data-en="Negotiation">Negociação</li>
          <li data-pt="Inglês avançado" data-en="Advanced English">Inglês avançado</li>
        </ul>
      </div>
    </div>
  </section>

  <hr />

  <!-- Certificados -->
  <section class="about-section">
    <span class="section-label" data-pt="CERTIFICADOS" data-en="CERTIFICATES">CERTIFICADOS</span>
    <div class="certs-grid">
      {certificados.map(cert => (
        <CertCard
          name={cert.name}
          issuer={cert.issuer}
          date={cert.date}
          type={cert.type as 'tech' | 'biz' | 'soft'}
          url={cert.url}
        />
      ))}
    </div>
  </section>

</Base>

<style>
  .page-header {
    padding: 48px 0 32px;
  }
  .page-title {
    font-size: 28px;
    font-weight: 500;
    color: var(--text-primary);
  }

  .about-section {
    padding: 8px 0;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 32px;
    align-items: start;
  }

  .avatar-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    text-align: center;
  }
  .avatar-img {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    border: 0.5px solid var(--border);
    object-fit: cover;
    object-position: center top;
    display: block;
  }
  .cargo {
    font-size: 12px;
    color: var(--text-hint);
    text-align: center;
  }

  .bio-col {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .bio-paras {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .bio-col p {
    font-size: 14px;
    color: var(--text-muted);
    line-height: 1.7;
  }
  .bio-col strong {
    color: var(--text-body);
  }
  .bio-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 4px;
  }

  /* Timeline */
  .timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-top: 16px;
  }
  .timeline-item {
    display: grid;
    grid-template-columns: 60px 1fr;
    gap: 20px;
    position: relative;
  }
  .timeline-year {
    font-size: 12px;
    color: var(--text-ghost);
    padding-top: 2px;
    text-align: right;
  }
  .timeline-content {
    padding-bottom: 24px;
    border-left: 0.5px solid var(--border);
    padding-left: 20px;
  }
  .timeline-title {
    font-size: 14px;
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: 4px;
  }
  .timeline-desc {
    font-size: 13px;
    color: var(--text-muted);
  }

  /* Skills */
  .skills-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    margin-top: 16px;
  }
  .skills-group-label {
    font-size: 11px;
    color: var(--text-hint);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    display: block;
    margin-bottom: 12px;
  }
  .skills-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .skills-list li {
    font-size: 14px;
    color: var(--text-muted);
    padding: 8px 12px;
    background: var(--bg-card);
    border: 0.5px solid var(--border);
    border-radius: var(--radius-md);
  }

  /* Certs */
  .certs-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
    margin-top: 16px;
  }

  @media (max-width: 768px) {
    .about-grid { grid-template-columns: 1fr; }
    .skills-grid { grid-template-columns: 1fr; }
    .certs-grid { grid-template-columns: 1fr; }
  }
</style>
