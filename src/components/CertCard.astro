---
interface Props {
  name: string;
  issuer: string;
  date: string;
  type: 'tech' | 'biz';
}

const { name, issuer, date, type } = Astro.props;

const typeLabel = type === 'tech' ? 'tech' : 'negócios';
---

<div class="card cert-card">
  <div class="cert-header">
    <span class="cert-name">{name}</span>
    <span class={`badge badge-${type === 'tech' ? 'dev' : 'mix'}`}>{typeLabel}</span>
  </div>
  <div class="cert-meta">
    <span class="cert-issuer">{issuer}</span>
    <span class="cert-date">{date}</span>
  </div>
</div>

<style>
  .cert-card {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .cert-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 8px;
  }
  .cert-name {
    font-size: 14px;
    font-weight: 500;
    color: var(--text-primary);
  }
  .cert-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .cert-issuer {
    font-size: 12px;
    color: var(--text-muted);
  }
  .cert-date {
    font-size: 11px;
    color: var(--text-hint);
  }
</style>
