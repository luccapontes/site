---
interface Props {
  name: string;
  issuer: string;
  date: string;
  type: 'tech' | 'biz' | 'soft';
  url?: string;
}

const { name, issuer, date, type, url } = Astro.props;

const typeLabelPt = type === 'tech' ? 'tech' : type === 'soft' ? 'soft skills' : 'negócios';
const typeLabelEn = type === 'tech' ? 'tech' : type === 'soft' ? 'soft skills' : 'business';
const badgeClass = type === 'tech' ? 'badge-dev' : type === 'soft' ? 'badge-mix' : 'badge-mix';
const hasLink = url && url.trim() !== '';
---

{hasLink ? (
  <a href={url} target="_blank" rel="noopener" class="card cert-card cert-card--link">
    <div class="cert-header">
      <span class="cert-name">{name}</span>
      <div class="cert-header-right">
        <span class={`badge ${badgeClass}`} data-pt={typeLabelPt} data-en={typeLabelEn}>{typeLabelPt}</span>
        <span class="cert-arrow">↗</span>
      </div>
    </div>
    <div class="cert-meta">
      <span class="cert-issuer">{issuer}</span>
      <span class="cert-date">{date}</span>
    </div>
  </a>
) : (
  <div class="card cert-card">
    <div class="cert-header">
      <span class="cert-name">{name}</span>
      <span class={`badge ${badgeClass}`} data-pt={typeLabelPt} data-en={typeLabelEn}>{typeLabelPt}</span>
    </div>
    <div class="cert-meta">
      <span class="cert-issuer">{issuer}</span>
      <span class="cert-date">{date}</span>
    </div>
  </div>
)}

<style>
  .cert-card {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .cert-card--link {
    text-decoration: none;
    cursor: pointer;
  }
  .cert-card--link:hover .cert-name {
    color: #ffffff;
  }
  .cert-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 8px;
  }
  .cert-header-right {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-shrink: 0;
  }
  .cert-name {
    font-size: 14px;
    font-weight: 500;
    color: var(--text-primary);
    transition: color 0.15s;
  }
  .cert-arrow {
    font-size: 12px;
    color: var(--text-hint);
    transition: color 0.15s;
  }
  .cert-card--link:hover .cert-arrow {
    color: var(--text-muted);
  }
  .cert-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .cert-issuer {
    font-size: 12px;
    color: var(--text-muted);
  }
  .cert-date {
    font-size: 11px;
    color: var(--text-hint);
  }
</style>
